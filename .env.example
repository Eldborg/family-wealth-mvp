# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# BACKEND CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/family_wealth_dev"

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT secret key - MUST be at least 32 characters in production
JWT_SECRET=your-secret-key-here-min-32-chars

# Frontend URL for email verification links
FRONTEND_URL=http://localhost:3000

# ============================================
# REDIS (Token Blacklist & Caching)
# ============================================
# Redis URL for distributed token blacklist and rate limiting
# Format: redis://[:password@]host:port/db
REDIS_URL=redis://localhost:6379

# ============================================
# EMAIL SERVICE (Production)
# ============================================
# Email service provider selection
EMAIL_SERVICE=sendgrid
# SendGrid API key
SENDGRID_API_KEY=
# Email sender address
EMAIL_FROM=noreply@familywealth.app
EMAIL_FROM_NAME=Family Wealth

# Alternative: Use SMTP directly
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=true

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGIN=http://localhost:3000

# ============================================
# RATE LIMITING
# ============================================
# Redis-based rate limiting (requires REDIS_URL)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
